---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'AI 技术教程博客' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="azDQKFOaF1WTTS9FXHmNz7lDeRDGITYuJfUqcTYDqEs" />
    <link rel="canonical" href={Astro.url.href} />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="zh_CN" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>" />
  </head>
  <body>
    <header>
      <div class="container inner">
        <a href={import.meta.env.BASE_URL} class="logo">ai<span>.</span>blog</a>
        <nav>
          <a href={import.meta.env.BASE_URL} data-i18n="nav.articles">文章</a>
          <a href={`${import.meta.env.BASE_URL}/tags/`} data-i18n="nav.tags">标签</a>
          <a href={`${import.meta.env.BASE_URL}/about/`} data-i18n="nav.about">关于</a>
          <a href="https://github.com" target="_blank">GitHub</a>
          <button id="lang-toggle" aria-label="Switch language">EN</button>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer>
      <div class="container">
        <span data-i18n="footer.text">专注 AI 工具评测与教程</span> · {new Date().getFullYear()}
      </div>
    </footer>

    <script>
      const i18n: Record<string, Record<string, string>> = {
        zh: {
          'nav.articles': '文章',
          'nav.tags': '标签',
          'nav.about': '关于',
          'footer.text': '专注 AI 工具评测与教程',
        },
        en: {
          'nav.articles': 'Articles',
          'nav.tags': 'Tags',
          'nav.about': 'About',
          'footer.text': 'AI Tools Reviews & Tutorials',
        },
      };

      const btn = document.getElementById('lang-toggle') as HTMLButtonElement;
      let lang = (localStorage.getItem('lang') || 'zh') as 'zh' | 'en';

      function applyLang(l: 'zh' | 'en') {
        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const key = el.dataset.i18n!;
          if (i18n[l][key]) el.textContent = i18n[l][key];
        });
        btn.textContent = l === 'zh' ? 'EN' : '中';
        document.documentElement.lang = l === 'zh' ? 'zh-CN' : 'en';
      }

      applyLang(lang);

      btn.addEventListener('click', () => {
        lang = lang === 'zh' ? 'en' : 'zh';
        localStorage.setItem('lang', lang);
        applyLang(lang);
      });
    </script>
  </body>
</html>
