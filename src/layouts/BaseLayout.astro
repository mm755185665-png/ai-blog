---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en';
}
const { title, description = 'AI 技术教程博客', lang = 'zh' } = Astro.props;
const htmlLang = lang === 'en' ? 'en' : 'zh-CN';
const ogLocale = lang === 'en' ? 'en_US' : 'zh_CN';
const base = import.meta.env.BASE_URL;
const articlesHref = `${base}/${lang}/`;
const tagsHref = `${base}/${lang}/tags/`;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="azDQKFOaF1WTTS9FXHmNz7lDeRDGITYuJfUqcTYDqEs" />
    <link rel="canonical" href={Astro.url.href} />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content={ogLocale} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="base-url" content={base} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>" />
  </head>
  <body>
    <header>
      <div class="container inner">
        <a href={`${base}/`} class="logo">ai<span>.</span>blog</a>
        <nav>
          <a href={articlesHref}>{lang === 'en' ? 'Articles' : '文章'}</a>
          <a href={`${base}/zh/tools/`}>{lang === 'en' ? 'Tools' : '工具'}</a>
          <a href={tagsHref}>{lang === 'en' ? 'Tags' : '标签'}</a>
          <a href={`${base}/about/`}>{lang === 'en' ? 'About' : '关于'}</a>
          <a href="https://github.com" target="_blank">GitHub</a>
          <button id="search-btn" aria-label="Search">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </button>
          <a id="lang-toggle" href="#" aria-label="Switch language">{lang === 'en' ? '中' : 'EN'}</a>
        </nav>
      </div>
      <div id="search-overlay" class="search-overlay" hidden>
        <input id="search-overlay-input" type="search" placeholder={lang === 'en' ? 'Search articles...' : '搜索文章...'} autocomplete="off" />
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer>
      <div class="container">
        {lang === 'en' ? 'AI Tools Reviews & Tutorials' : '专注 AI 工具评测与教程'} · {new Date().getFullYear()}
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('lang-toggle') as HTMLAnchorElement;
      const path = window.location.pathname;
      if (path.includes('/zh/')) {
        toggle.href = path.replace('/zh/', '/en/');
      } else if (path.includes('/en/')) {
        toggle.href = path.replace('/en/', '/zh/');
      }

      // Search
      const searchBtn = document.getElementById('search-btn') as HTMLButtonElement;
      const overlay = document.getElementById('search-overlay') as HTMLDivElement;
      const searchInput = document.getElementById('search-overlay-input') as HTMLInputElement;
      const base = document.querySelector('meta[name="base-url"]')?.getAttribute('content') || '/ai-blog';
      const lang = document.documentElement.lang.startsWith('en') ? 'en' : 'zh';

      searchBtn.addEventListener('click', () => {
        overlay.hidden = !overlay.hidden;
        if (!overlay.hidden) searchInput.focus();
      });

      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && searchInput.value.trim()) {
          window.location.href = `${base}/search/?q=${encodeURIComponent(searchInput.value.trim())}&lang=${lang}`;
        }
        if (e.key === 'Escape') { overlay.hidden = true; }
      });

      document.addEventListener('keydown', (e) => {
        if ((e.key === 'k' && (e.metaKey || e.ctrlKey)) || e.key === '/') {
          e.preventDefault();
          overlay.hidden = false;
          searchInput.focus();
        }
      });
    </script>
  </body>
</html>
