---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts-zh');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

// 从 markdown 原文提取 H2/H3 标题生成 TOC
const rawContent = post.body;
const headingRegex = /^(#{2,3})\s+(.+)$/gm;
const tocItems: { level: number; text: string; id: string }[] = [];
let match;
while ((match = headingRegex.exec(rawContent)) !== null) {
  const level = match[1].length;
  const text = match[2].trim();
  const id = text.toLowerCase().replace(/[^\w\u4e00-\u9fff]+/g, '-').replace(/^-|-$/g, '');
  tocItems.push({ level, text, id });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.summary,
  "datePublished": post.data.date.toISOString().split('T')[0],
  "dateModified": post.data.date.toISOString().split('T')[0],
  "url": Astro.url.href,
  "publisher": { "@type": "Organization", "name": "AI Blog", "url": import.meta.env.SITE + import.meta.env.BASE_URL },
  "keywords": post.data.tags?.join(', '),
};
---

<BaseLayout title={post.data.title} description={post.data.summary} lang="zh">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="article-outer">
    <div class="article-main">
      <a href={`${import.meta.env.BASE_URL}/zh/`} class="back-link">← 返回列表</a>
      <article>
        <header class="article-header">
          <div class="tag-list">
            {post.data.tags.map((tag) => (
              <a href={`${import.meta.env.BASE_URL}/zh/tags/${tag}/`} class="tag">#{tag}</a>
            ))}
          </div>
          <h1>{post.data.title}</h1>
          <div class="article-meta">
            <span>{formatDate(post.data.date)}</span>
            <span class="badge badge-difficulty">{post.data.difficulty}</span>
          </div>
        </header>
        {post.data.cover && (
          <img src={post.data.cover} alt={post.data.title} class="cover-image" />
        )}
        <div class="prose"><Content /></div>
      </article>
    </div>

    {tocItems.length > 0 && (
      <aside class="toc-sidebar">
        <div class="toc-box">
          <div class="toc-title">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>
            目录
          </div>
          <nav>
            <ul class="toc-list">
              {tocItems.map((item) => (
                <li class={`toc-item toc-h${item.level}`}>
                  <a href={`#${item.id}`} class="toc-link">{item.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>
    )}
  </div>

  <script>
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    const headings = Array.from(document.querySelectorAll<HTMLElement>('.prose h2, .prose h3'));
    const toc = document.querySelector<HTMLElement>('.toc-sidebar');
    const prose = document.querySelector<HTMLElement>('.prose');
    const articleMain = document.querySelector<HTMLElement>('.article-main');

    // 用 fixed 定位，把目录放在文章右侧
    function positionToc() {
      if (!toc || !articleMain) return;
      const rect = articleMain.getBoundingClientRect();
      const left = rect.right + window.scrollX + 32;
      const viewportWidth = window.innerWidth;
      // 只有右侧有足够空间时才显示
      if (viewportWidth - rect.right > 260) {
        toc.style.left = (rect.right + 32) + 'px';
        toc.style.display = 'block';
      } else {
        toc.style.display = 'none';
      }
    }

    positionToc();
    window.addEventListener('resize', positionToc);

    // 滚动高亮当前章节
    function onScroll() {
      let current = '';
      for (const h of headings) {
        if (h.getBoundingClientRect().top <= 100) current = h.id;
      }
      links.forEach(a => {
        a.classList.toggle('toc-active', a.getAttribute('href') === `#${current}`);
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
  </script>
</BaseLayout>
