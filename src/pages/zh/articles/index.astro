---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts-zh');
const base = import.meta.env.BASE_URL;

const CATEGORIES = [
  { name: '全部',       slug: 'all',     keywords: [] },
  { name: 'AI编程工具', slug: 'coding',  keywords: ['编程', 'Cursor', 'Copilot', 'Vibe', 'CodeGeeX', 'Windsurf', 'Trae', 'Claude Code'] },
  { name: 'AI大模型',   slug: 'models',  keywords: ['ChatGPT', 'Claude', 'DeepSeek', 'Gemini', '大模型', '平替'] },
  { name: 'AI图像生成', slug: 'image',   keywords: ['图像', '绘画', 'Midjourney', 'AI图'] },
  { name: 'AI写作工具', slug: 'writing', keywords: ['写作', '自媒体'] },
  { name: '综合推荐',   slug: 'general', keywords: [] },
];

function matchCat(tags: string[]): string {
  const s = tags.join(' ');
  for (const c of CATEGORIES) {
    if (c.slug === 'all' || c.slug === 'general') continue;
    if (c.keywords.some(k => s.includes(k))) return c.slug;
  }
  return 'general';
}

// 分组
const grouped: Record<string, typeof allPosts> = {};
for (const c of CATEGORIES) grouped[c.slug] = [];
for (const p of allPosts) {
  const slug = matchCat(p.data.tags || []);
  grouped[slug].push(p);
  grouped['all'].push(p);
}
for (const slug of Object.keys(grouped))
  grouped[slug].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 出现 ≥2 次的标签，按分类归属
const tagCount = new Map<string, number>();
for (const p of allPosts)
  for (const t of p.data.tags || [])
    tagCount.set(t, (tagCount.get(t) ?? 0) + 1);

// 每个分类下的热门标签（≥2次）
const catTags: Record<string, string[]> = { all: [] };
for (const c of CATEGORIES) catTags[c.slug] = [];

for (const p of allPosts) {
  const slug = matchCat(p.data.tags || []);
  for (const t of p.data.tags || []) {
    if ((tagCount.get(t) ?? 0) >= 2) {
      if (!catTags[slug].includes(t)) catTags[slug].push(t);
      if (!catTags['all'].includes(t)) catTags['all'].push(t);
    }
  }
}

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}

// 序列化给客户端 JS
const groupedSlugs = Object.fromEntries(
  Object.entries(grouped).map(([k, v]) => [k, v.map(p => p.slug)])
);
const postMeta = Object.fromEntries(
  allPosts.map(p => [p.slug, {
    title: p.data.title,
    date: formatDate(p.data.date),
    tags: p.data.tags,
    summary: p.data.summary ?? '',
    cover: p.data.cover ?? '',
    href: `${base}/zh/posts/${p.slug}/`,
  }])
);
---

<BaseLayout title="文章索引 · AI博客" description="按分类和标签浏览所有AI工具评测与教程文章" lang="zh">

  <div class="page-header">
    <h1>文章索引</h1>
    <p class="page-desc">共 {allPosts.length} 篇文章</p>
  </div>

  <!-- 分类 Tab -->
  <nav class="cat-tabs" id="cat-tabs">
    {CATEGORIES.filter(c => c.slug === 'all' || grouped[c.slug].length > 0).map((cat, i) => (
      <button class={`cat-tab${i === 0 ? ' active' : ''}`} data-cat={cat.slug}>
        {cat.name}
        <span class="tab-count">{grouped[cat.slug].length}</span>
      </button>
    ))}
  </nav>

  <!-- 热门标签 -->
  <div class="tag-bar" id="tag-bar">
    {/* 由 JS 动态渲染 */}
  </div>

  <!-- 文章列表 -->
  <ul class="post-list" id="post-list">
    {/* 由 JS 动态渲染 */}
  </ul>

</BaseLayout>

<script define:vars={{ groupedSlugs, postMeta, catTags }}>
  let currentCat = 'all';
  let currentTag = '';

  const tabsEl   = document.getElementById('cat-tabs');
  const tagBarEl = document.getElementById('tag-bar');
  const listEl   = document.getElementById('post-list');

  function renderTags() {
    const tags = catTags[currentCat] || [];
    if (!tags.length) { tagBarEl.innerHTML = ''; return; }
    tagBarEl.innerHTML = tags.map(t =>
      `<button class="tag-chip${t === currentTag ? ' active' : ''}" data-tag="${t}">#${t}</button>`
    ).join('');
    tagBarEl.querySelectorAll('.tag-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        const t = btn.dataset.tag;
        currentTag = currentTag === t ? '' : t;
        renderTags();
        renderPosts();
      });
    });
  }

  function renderPosts() {
    let slugs = groupedSlugs[currentCat] || [];
    if (currentTag) {
      slugs = slugs.filter(s => postMeta[s]?.tags?.includes(currentTag));
    }
    if (!slugs.length) {
      listEl.innerHTML = '<li class="empty">暂无文章</li>';
      return;
    }
    listEl.innerHTML = slugs.map(s => {
      const p = postMeta[s];
      return `
        <li class="post-card">
          <a href="${p.href}" class="post-card-link">
            <div class="post-card-cover-wrap">
              ${p.cover
                ? `<img src="${p.cover}" alt="${p.title}" class="post-card-cover" loading="lazy" />`
                : `<div class="post-card-cover post-card-cover--placeholder"></div>`
              }
            </div>
            <div class="post-card-body">
              <div class="post-card-meta">
                ${p.tags[0] ? `<span class="post-card-tag">#${p.tags[0]}</span>` : ''}
                <span class="post-card-date">${p.date}</span>
              </div>
              <h3 class="post-card-title">${p.title}</h3>
              ${p.summary ? `<p class="post-card-summary">${p.summary}</p>` : ''}
            </div>
          </a>
        </li>`;
    }).join('');
  }

  // 分类 tab 点击
  tabsEl.querySelectorAll('.cat-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      tabsEl.querySelectorAll('.cat-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentCat = btn.dataset.cat;
      currentTag = '';
      renderTags();
      renderPosts();
    });
  });

  // 初始渲染
  renderTags();
  renderPosts();
</script>

<style is:global>
  .page-desc { color: var(--text-dim); font-size: 0.9rem; margin-top: 0.2rem; }

  .cat-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1.5rem 0 1rem;
  }
  .cat-tab {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: none;
    font-size: 0.875rem;
    color: var(--text-dim);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .cat-tab:hover, .cat-tab.active {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(88,166,255,0.07);
  }
  .tab-count { font-size: 0.75rem; opacity: 0.7; }

  .tag-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    min-height: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .tag-chip {
    padding: 0.2rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: none;
    font-size: 0.8rem;
    color: var(--text-dim);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .tag-chip:hover, .tag-chip.active {
    border-color: var(--accent);
    color: var(--accent);
  }

  .post-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 860px) { .post-list { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .post-list { grid-template-columns: 1fr; } }

  .post-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .post-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }
  .post-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }
  .post-card-link:hover { text-decoration: none; }

  .post-card-cover-wrap {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--bg-card);
  }
  .post-card-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .post-card:hover .post-card-cover { transform: scale(1.03); }
  .post-card-cover--placeholder {
    width: 100%;
    height: 100%;
    background: var(--border);
  }

  .post-card-body {
    padding: 0.85rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.45rem;
  }
  .post-card-tag {
    font-size: 0.72rem;
    color: var(--accent);
    background: rgba(88,166,255,0.1);
    border-radius: 4px;
    padding: 0.1rem 0.45rem;
  }
  .post-card-date { font-size: 0.72rem; color: var(--text-dim); }
  .post-card-title {
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
    color: var(--text);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-card:hover .post-card-title { color: var(--accent); }
  .post-card-summary {
    font-size: 0.78rem;
    color: var(--text-dim);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
  .empty { padding: 2rem 0; color: var(--text-dim); font-size: 0.9rem; }
</style>
