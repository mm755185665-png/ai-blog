---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import newsData from '../../../data/news.json';

const base = import.meta.env.BASE_URL;

const SOURCE_COLORS: Record<string, string> = {
  '量子位':         '#3b82f6',
  '机器之心':       '#8b5cf6',
  '少数派':         '#10b981',
  '36Kr':          '#f59e0b',
  '爱范儿':         '#ef4444',
  '极客公园':       '#06b6d4',
  '新智元':         '#6366f1',
  '虎嗅':          '#f97316',
  '钛媒体':         '#84cc16',
  'IT之家':         '#ec4899',
  'TechCrunch AI':  '#7c3aed',
  'The Verge AI':   '#0ea5e9',
  'VentureBeat AI': '#d97706',
  'MIT Tech Review': '#059669',
  'Google AI':      '#4285f4',
  'Hugging Face':   '#ff9d00',
};

const SOURCE_DOMAINS: Record<string, string> = {
  '量子位':         'qbitai.com',
  '机器之心':       'jiqizhixin.com',
  '少数派':         'sspai.com',
  '36Kr':          '36kr.com',
  '爱范儿':         'ifanr.com',
  '极客公园':       'geekpark.net',
  '新智元':         'aizhuanzhu.com',
  '虎嗅':          'huxiu.com',
  '钛媒体':         'tmtpost.com',
  'IT之家':         'ithome.com',
  'TechCrunch AI':  'techcrunch.com',
  'The Verge AI':   'theverge.com',
  'VentureBeat AI': 'venturebeat.com',
  'MIT Tech Review': 'technologyreview.com',
  'Google AI':      'blog.google',
  'Hugging Face':   'huggingface.co',
};

const items = newsData.items as {
  title: string; title_zh: string; title_en: string;
  url: string; source: string;
  summary: string; summary_zh: string; summary_en: string;
  date: string;
  image?: string;
}[];

// ── 分类推导 ──────────────────────────────────────────────────────────────────
const CAT_KEYWORDS: Record<string, string[]> = {
  '大模型': ['模型', 'gpt', 'claude', 'gemini', 'llm', '语言模型', 'llama', 'deepseek', 'qwen', 'grok', 'mistral', 'o1', 'o3', 'phi'],
  '图像视频': ['图像', '视频', 'sora', '文生图', '生图', 'dall', 'stable diffusion', 'midjourney', '文生视频', '图生视频', 'kling', 'runway', 'imagen'],
  '行业动态': ['融资', '收购', '估值', '上市', '投资', '亿美元', '裁员', '合并', '融到', '领投'],
  '工具产品': ['发布', '推出', '上线', '更新', '版本', '功能', '新功能', '升级', '支持', '接入'],
};

function getCat(item: { title_zh?: string; title?: string }): string {
  const text = ((item.title_zh || item.title) ?? '').toLowerCase();
  for (const [cat, kws] of Object.entries(CAT_KEYWORDS)) {
    if (kws.some(kw => text.includes(kw))) return cat;
  }
  return '其他';
}

// ── 阅读时长（中文约 400 字/分钟）────────────────────────────────────────────
function getReadTime(item: { summary_zh?: string; summary?: string }): number {
  const len = (item.summary_zh || item.summary || '').length;
  return Math.max(1, Math.ceil(len / 400));
}

const sources = [...new Set(items.map(i => i.source))];

// 按日期分组
const grouped: Record<string, typeof items> = {};
for (const item of items) {
  const day = item.date?.slice(0, 10) ?? 'unknown';
  if (!grouped[day]) grouped[day] = [];
  grouped[day].push(item);
}
const days = Object.keys(grouped).sort((a, b) => b.localeCompare(a));

// ── 置顶精选：最新一天的前 3 条 ───────────────────────────────────────────────
const featured = (grouped[days[0]] ?? items).slice(0, 3);

function dayLabel(d: string) {
  const today = new Date().toISOString().slice(0, 10);
  const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
  if (d === today) return '今日';
  if (d === yesterday) return '昨日';
  return d.slice(5).replace('-', '/');
}

// 所有分类（用于筛选）
const allCats = ['全部', '大模型', '图像视频', '行业动态', '工具产品', '其他'];
const CAT_COLORS: Record<string, string> = {
  '大模型':  '#8b5cf6',
  '图像视频': '#ec4899',
  '行业动态': '#f59e0b',
  '工具产品': '#10b981',
  '其他':    '#64748b',
};
---

<BaseLayout
  title="每日 AI 资讯 · AI 新闻速报"
  description="每日自动抓取量子位、机器之心等 AI 资讯，掌握最新人工智能动态。"
  lang="zh"
>

<div class="news-page">

  <!-- Hero -->
  <div class="news-hero">
    <div class="hero-badge">每日自动更新</div>
    <h1 class="hero-title">AI 资讯速报</h1>
    <p class="hero-sub">省去刷信息的时间，只看 AI 最重要的事</p>
    <div class="hero-stats">
      <span class="hstat"><strong>{items.length}</strong> 条资讯</span>
      <span class="hstat-sep">·</span>
      <span class="hstat"><strong>{sources.length}</strong> 个来源</span>
      <span class="hstat-sep">·</span>
      <span class="hstat">更新于 {newsData.updated?.slice(0, 10)}</span>
    </div>
  </div>

  <!-- ── 置顶精选 ── -->
  <div class="featured-section">
    <div class="featured-header">
      <span class="featured-label">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        今日精选
      </span>
    </div>
    <div class="featured-grid">
      {featured.map(item => {
        const color = SOURCE_COLORS[item.source] ?? '#64748b';
        const domain = (() => { try { return new URL(item.url).hostname; } catch { return 'example.com'; } })();
        const r = parseInt(color.slice(1,3),16);
        const g = parseInt(color.slice(3,5),16);
        const b = parseInt(color.slice(5,7),16);
        const readTime = getReadTime(item);
        return (
          <a href={item.url} target="_blank" rel="noopener noreferrer"
            class="fc-card"
            style={`--fc:${color};--fc-rgb:${r},${g},${b}`}
          >
            <div class="fc-cover">
              {item.image
                ? <img src={item.image} alt="" class="fc-img" loading="lazy" />
                : <div class="fc-placeholder">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  </div>
              }
              <div class="fc-source-badge">
                <img src={`https://www.google.com/s2/favicons?domain=${domain}&sz=32`} width="12" height="12" alt="" />
                {item.source}
              </div>
            </div>
            <div class="fc-body">
              <h3 class="fc-title">{item.title_zh || item.title}</h3>
              {(item.summary_zh || item.summary) && (
                <p class="fc-summary">{item.summary_zh || item.summary}</p>
              )}
              <div class="fc-footer">
                <span class="fc-time">{item.date?.slice(5,10)}</span>
                <span class="fc-read">约 {readTime} 分钟</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>

  <!-- ── 分类筛选 ── -->
  <div class="cat-filter-wrap">
    <div class="cat-filter" id="cat-filter">
      {allCats.map(cat => (
        <button
          class={`cpill${cat === '全部' ? ' active' : ''}`}
          data-cat={cat}
          style={cat !== '全部' ? `--cc:${CAT_COLORS[cat] ?? '#64748b'}` : ''}
        >
          {cat}
        </button>
      ))}
    </div>
  </div>

  <!-- ── 来源筛选 ── -->
  <div class="filter-wrap">
    <div class="filter-bar" id="filter-bar">
      <button class="fpill active" data-source="all">
        <span class="fpill-dot" style="background:var(--accent)"></span>
        全部
        <span class="fpill-count">{items.length}</span>
      </button>
      {sources.map(src => {
        const color = SOURCE_COLORS[src] ?? '#64748b';
        return (
          <button class="fpill" data-source={src} style={`--sc:${color}`}>
            <img
              src={`https://www.google.com/s2/favicons?domain=${SOURCE_DOMAINS[src] ?? 'example.com'}&sz=32`}
              width="12" height="12" class="fpill-favicon" alt=""
            />
            {src}
            <span class="fpill-count">{items.filter(i => i.source === src).length}</span>
          </button>
        );
      })}
    </div>
  </div>

  <!-- ── 资讯 Feed ── -->
  <div class="feed" id="news-feed">
    {days.map(day => (
      <div class="day-group" data-day={day}>
        <div class="day-label">
          <span class="day-text">{dayLabel(day)}</span>
          <span class="day-count">{grouped[day].length} 条</span>
        </div>
        <ul class="feed-list">
          {grouped[day].map(item => {
            const color = SOURCE_COLORS[item.source] ?? '#64748b';
            const domain = (() => { try { return new URL(item.url).hostname; } catch { return 'example.com'; } })();
            const cat = getCat(item);
            const readTime = getReadTime(item);
            const catColor = CAT_COLORS[cat] ?? '#64748b';
            return (
              <li class="feed-item" data-source={item.source} data-cat={cat} style={`--ic:${color}`}>
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="feed-link">
                  <div class="feed-content">
                    <div class="feed-meta">
                      <img
                        src={`https://www.google.com/s2/favicons?domain=${domain}&sz=32`}
                        width="14" height="14"
                        class="feed-favicon"
                        loading="lazy"
                        alt=""
                      />
                      <span class="feed-source">{item.source}</span>
                      <span class="feed-sep">·</span>
                      <span class="feed-time">{item.date?.slice(11, 16) || item.date?.slice(5, 10)}</span>
                      <span class="feed-sep">·</span>
                      <span class="cat-tag" style={`--ct:${catColor}`}>{cat}</span>
                      <span class="read-time">约 {readTime} 分钟</span>
                    </div>
                    <h2 class="feed-title">{item.title_zh || item.title}</h2>
                    {(item.summary_zh || item.summary) && (
                      <p class="feed-summary">{item.summary_zh || item.summary}</p>
                    )}
                  </div>
                  <div class="feed-img-wrap">
                    {item.image
                      ? <img src={item.image} alt="" class="feed-img" loading="lazy" />
                      : <div class="feed-img-placeholder" style={`--ic:${color}`}></div>
                    }
                  </div>
                  <svg class="feed-arrow" viewBox="0 0 16 16" fill="none">
                    <path d="M6 12l4-4-4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}

    {items.length === 0 && (
      <div class="feed-empty">
        <p>暂无资讯，今日资讯将在北京时间 08:00 自动更新</p>
      </div>
    )}
  </div>

</div>

</BaseLayout>

<script>
  // ── 分类筛选 ──
  const catFilter = document.getElementById('cat-filter')!;
  const filterBar = document.getElementById('filter-bar')!;
  const feed = document.getElementById('news-feed')!;
  const allItems = Array.from(feed.querySelectorAll<HTMLElement>('.feed-item'));
  const dayGroups = Array.from(feed.querySelectorAll<HTMLElement>('.day-group'));

  let activeSource = 'all';
  let activeCat = '全部';

  function applyFilters() {
    allItems.forEach(item => {
      const matchSrc = activeSource === 'all' || item.dataset.source === activeSource;
      const matchCat = activeCat === '全部' || item.dataset.cat === activeCat;
      item.style.display = (matchSrc && matchCat) ? '' : 'none';
    });
    dayGroups.forEach(group => {
      const visible = Array.from(group.querySelectorAll<HTMLElement>('.feed-item'))
        .some(el => el.style.display !== 'none');
      (group as HTMLElement).style.display = visible ? '' : 'none';
    });
  }

  catFilter.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.cpill');
    if (!btn) return;
    catFilter.querySelectorAll('.cpill').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeCat = btn.dataset.cat ?? '全部';
    applyFilters();
  });

  filterBar.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.fpill');
    if (!btn) return;
    filterBar.querySelectorAll('.fpill').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeSource = btn.dataset.source ?? 'all';
    applyFilters();
  });
</script>

<style>
.news-page {
  max-width: 860px;
  margin: 0 auto;
  padding-bottom: 5rem;
}

/* ── Hero ── */
.news-hero {
  text-align: center;
  padding: 2.5rem 0 2rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 1.75rem;
}
.hero-badge {
  display: inline-block;
  padding: 0.2rem 0.75rem;
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 0.72rem;
  color: var(--text-dim);
  font-family: var(--font-mono);
  margin-bottom: 0.9rem;
  background: var(--bg-card);
}
.hero-title {
  font-size: clamp(1.6rem, 4vw, 2.2rem);
  font-weight: 800;
  margin: 0 0 0.4rem;
  letter-spacing: -0.02em;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-2) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-sub {
  color: var(--text-dim);
  font-size: 0.9rem;
  margin: 0 0 0.9rem;
}
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  color: var(--text-dim);
  flex-wrap: wrap;
}
.hstat strong { color: var(--text); font-weight: 600; }
.hstat-sep { opacity: 0.4; }

/* ── 置顶精选 ── */
.featured-section { margin-bottom: 2rem; }
.featured-header {
  display: flex;
  align-items: center;
  margin-bottom: 0.85rem;
}
.featured-label {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.78rem;
  font-weight: 700;
  font-family: var(--font-mono);
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.featured-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
}
@media (max-width: 640px) {
  .featured-grid { grid-template-columns: 1fr; }
}

.fc-card {
  display: flex;
  flex-direction: column;
  border-radius: 12px;
  border: 1px solid rgba(var(--fc-rgb, 79,172,254), 0.18);
  border-top: 3px solid var(--fc, var(--accent));
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  background: linear-gradient(160deg, rgba(var(--fc-rgb,79,172,254),0.06) 0%, var(--bg-card) 60%);
  transition: transform 0.15s, box-shadow 0.2s, border-color 0.2s;
}
.fc-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 36px rgba(var(--fc-rgb,79,172,254), 0.18);
  border-color: var(--fc, var(--accent));
  text-decoration: none;
}

.fc-cover {
  position: relative;
  width: 100%;
  height: 130px;
  overflow: hidden;
  background: var(--bg-card);
}
.fc-img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s;
}
.fc-card:hover .fc-img { transform: scale(1.05); }

.fc-placeholder {
  width: 100%; height: 100%;
  background: linear-gradient(135deg,
    rgba(var(--fc-rgb,79,172,254), 0.25) 0%,
    rgba(var(--fc-rgb,79,172,254), 0.08) 100%
  );
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--fc, var(--accent));
}

.fc-source-badge {
  position: absolute;
  bottom: 7px; left: 8px;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 2px 8px;
  border-radius: 999px;
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(4px);
  font-size: 0.68rem;
  font-weight: 600;
  color: #fff;
}

.fc-body {
  padding: 12px 14px 14px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.fc-title {
  font-size: 0.875rem;
  font-weight: 600;
  line-height: 1.45;
  margin: 0 0 0.4rem;
  color: var(--text);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.fc-card:hover .fc-title { color: var(--fc, var(--accent)); }
.fc-summary {
  font-size: 0.75rem;
  color: var(--text-dim);
  line-height: 1.5;
  margin: 0 0 auto;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.fc-footer {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-top: 0.6rem;
}
.fc-time, .fc-read {
  font-size: 0.68rem;
  font-family: var(--font-mono);
  color: var(--text-dim);
}

/* ── 分类筛选 ── */
.cat-filter-wrap {
  margin-bottom: 0.6rem;
}
.cat-filter {
  display: flex;
  gap: 0.35rem;
  flex-wrap: wrap;
}
.cpill {
  padding: 0.25rem 0.75rem;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: transparent;
  color: var(--text-dim);
  font-size: 0.78rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.15s;
}
.cpill:hover {
  border-color: var(--cc, var(--accent));
  color: var(--cc, var(--accent));
}
.cpill.active {
  background: var(--cc, var(--accent));
  border-color: var(--cc, var(--accent));
  color: #fff;
}
/* 全部按钮没有 --cc，单独处理 */
.cpill[data-cat="全部"].active {
  background: var(--accent);
  border-color: var(--accent);
}
.cpill[data-cat="全部"]:hover:not(.active) {
  border-color: var(--accent);
  color: var(--accent);
}

/* ── 来源筛选 ── */
.filter-wrap {
  margin-bottom: 1.75rem;
  overflow-x: auto;
  scrollbar-width: none;
}
.filter-wrap::-webkit-scrollbar { display: none; }
.filter-bar {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
  min-width: max-content;
}
.fpill {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.3rem 0.7rem;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: transparent;
  color: var(--text-dim);
  font-size: 0.78rem;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.fpill:hover {
  border-color: var(--sc, var(--accent));
  color: var(--sc, var(--accent));
}
.fpill.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
  font-weight: 600;
}
.fpill-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.fpill-favicon {
  border-radius: 2px;
  flex-shrink: 0;
  opacity: 0.85;
}
.fpill-count {
  background: rgba(255,255,255,0.15);
  border-radius: 999px;
  padding: 0 0.35rem;
  font-size: 0.7rem;
  line-height: 1.4;
}
.fpill:not(.active) .fpill-count {
  background: var(--border);
  color: var(--text-dim);
}

/* ── Day group ── */
.day-group { margin-bottom: 2rem; }
.day-label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.6rem;
}
.day-text {
  font-size: 0.78rem;
  font-weight: 700;
  font-family: var(--font-mono);
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.day-count {
  font-size: 0.7rem;
  color: var(--text-dim);
  background: var(--border);
  border-radius: 999px;
  padding: 0.05rem 0.45rem;
}

/* ── Feed list ── */
.feed-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
}
.feed-item {
  border-left: 3px solid var(--ic);
  border-bottom: 1px solid var(--border);
  transition: background 0.12s;
}
.feed-item:last-child { border-bottom: none; }
.feed-item:hover { background: rgba(255,255,255,0.03); }

.feed-link {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  padding: 0.9rem 1rem;
  text-decoration: none;
  color: inherit;
}
.feed-link:hover { text-decoration: none; }

.feed-content { flex: 1; min-width: 0; }

.feed-meta {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  margin-bottom: 0.35rem;
  flex-wrap: wrap;
}
.feed-favicon {
  border-radius: 3px;
  opacity: 0.8;
  flex-shrink: 0;
}
.feed-source {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--ic);
