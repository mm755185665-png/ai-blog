---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import newsData from '../../../data/news.json';

const base = import.meta.env.BASE_URL;

const SOURCE_COLORS: Record<string, string> = {
  '量子位':         '#3b82f6',
  '机器之心':       '#8b5cf6',
  '少数派':         '#10b981',
  '36Kr':          '#f59e0b',
  '爱范儿':         '#ef4444',
  '极客公园':       '#06b6d4',
  '新智元':         '#6366f1',
  '虎嗅':          '#f97316',
  '钛媒体':         '#84cc16',
  'IT之家':         '#ec4899',
  'TechCrunch AI':  '#7c3aed',
  'The Verge AI':   '#0ea5e9',
  'VentureBeat AI': '#d97706',
  'MIT Tech Review': '#059669',
  'Google AI':      '#4285f4',
  'Hugging Face':   '#ff9d00',
};

const SOURCE_DOMAINS: Record<string, string> = {
  '量子位':         'qbitai.com',
  '机器之心':       'jiqizhixin.com',
  '少数派':         'sspai.com',
  '36Kr':          '36kr.com',
  '爱范儿':         'ifanr.com',
  '极客公园':       'geekpark.net',
  '新智元':         'aizhuanzhu.com',
  '虎嗅':          'huxiu.com',
  '钛媒体':         'tmtpost.com',
  'IT之家':         'ithome.com',
  'TechCrunch AI':  'techcrunch.com',
  'The Verge AI':   'theverge.com',
  'VentureBeat AI': 'venturebeat.com',
  'MIT Tech Review': 'technologyreview.com',
  'Google AI':      'blog.google',
  'Hugging Face':   'huggingface.co',
};

const items = newsData.items as {
  title: string; title_zh: string; title_en: string;
  url: string; source: string;
  summary: string; summary_zh: string; summary_en: string;
  date: string;
}[];

const sources = [...new Set(items.map(i => i.source))];

// 按日期分组
const grouped: Record<string, typeof items> = {};
for (const item of items) {
  const day = item.date?.slice(0, 10) ?? 'unknown';
  if (!grouped[day]) grouped[day] = [];
  grouped[day].push(item);
}
const days = Object.keys(grouped).sort((a, b) => b.localeCompare(a));

function dayLabel(d: string) {
  const today = new Date().toISOString().slice(0, 10);
  const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
  if (d === today) return '今日';
  if (d === yesterday) return '昨日';
  return d.slice(5).replace('-', '/');
}
---

<BaseLayout
  title="每日 AI 资讯 · AI 新闻速报"
  description="每日自动抓取量子位、机器之心等 AI 资讯，掌握最新人工智能动态。"
  lang="zh"
>

<div class="news-page">

  <!-- Hero -->
  <div class="news-hero">
    <div class="hero-badge">每日自动更新</div>
    <h1 class="hero-title">AI 资讯速报</h1>
    <p class="hero-sub">省去刷信息的时间，只看 AI 最重要的事</p>
    <div class="hero-stats">
      <span class="hstat"><strong>{items.length}</strong> 条资讯</span>
      <span class="hstat-sep">·</span>
      <span class="hstat"><strong>{sources.length}</strong> 个来源</span>
      <span class="hstat-sep">·</span>
      <span class="hstat">更新于 {newsData.updated?.slice(0, 10)}</span>
    </div>
  </div>

  <!-- 来源筛选 -->
  <div class="filter-wrap">
    <div class="filter-bar" id="filter-bar">
      <button class="fpill active" data-source="all">
        <span class="fpill-dot" style="background:var(--accent)"></span>
        全部
        <span class="fpill-count">{items.length}</span>
      </button>
      {sources.map(src => {
        const color = SOURCE_COLORS[src] ?? '#64748b';
        return (
          <button class="fpill" data-source={src} style={`--sc:${color}`}>
            <img
              src={`https://www.google.com/s2/favicons?domain=${SOURCE_DOMAINS[src] ?? 'example.com'}&sz=32`}
              width="12" height="12" class="fpill-favicon" alt=""
            />
            {src}
            <span class="fpill-count">{items.filter(i => i.source === src).length}</span>
          </button>
        );
      })}
    </div>
  </div>

  <!-- 资讯 Feed -->
  <div class="feed" id="news-feed">
    {days.map(day => (
      <div class="day-group" data-day={day}>
        <div class="day-label">
          <span class="day-text">{dayLabel(day)}</span>
          <span class="day-count">{grouped[day].length} 条</span>
        </div>
        <ul class="feed-list">
          {grouped[day].map(item => {
            const color = SOURCE_COLORS[item.source] ?? '#64748b';
            const domain = (() => { try { return new URL(item.url).hostname; } catch { return 'example.com'; } })();
            return (
              <li class="feed-item" data-source={item.source} style={`--ic:${color}`}>
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="feed-link">
                  <div class="feed-content">
                    <div class="feed-meta">
                      <img
                        src={`https://www.google.com/s2/favicons?domain=${domain}&sz=32`}
                        width="14" height="14"
                        class="feed-favicon"
                        loading="lazy"
                        alt=""
                      />
                      <span class="feed-source">{item.source}</span>
                      <span class="feed-sep">·</span>
                      <span class="feed-time">{item.date?.slice(11, 16) || item.date?.slice(5, 10)}</span>
                    </div>
                    <h2 class="feed-title">{item.title_zh || item.title}</h2>
                    {(item.summary_zh || item.summary) && (
                      <p class="feed-summary">{item.summary_zh || item.summary}</p>
                    )}
                  </div>
                  <svg class="feed-arrow" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 12l4-4-4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}

    {items.length === 0 && (
      <div class="feed-empty">
        <p>暂无资讯，今日资讯将在北京时间 08:00 自动更新</p>
      </div>
    )}
  </div>

</div>

</BaseLayout>

<script>
  const bar = document.getElementById('filter-bar')!;
  const feed = document.getElementById('news-feed')!;
  const allItems = Array.from(feed.querySelectorAll<HTMLElement>('.feed-item'));
  const dayGroups = Array.from(feed.querySelectorAll<HTMLElement>('.day-group'));

  bar.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.fpill');
    if (!btn) return;
    bar.querySelectorAll('.fpill').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const src = btn.dataset.source ?? 'all';

    allItems.forEach(item => {
      item.style.display = (src === 'all' || item.dataset.source === src) ? '' : 'none';
    });

    // 隐藏空的日期组
    dayGroups.forEach(group => {
      const visible = Array.from(group.querySelectorAll<HTMLElement>('.feed-item'))
        .some(el => el.style.display !== 'none');
      (group as HTMLElement).style.display = visible ? '' : 'none';
    });
  });
</script>

<style>
.news-page {
  max-width: 780px;
  margin: 0 auto;
  padding-bottom: 5rem;
}

/* ── Hero ── */
.news-hero {
  text-align: center;
  padding: 2.5rem 0 2rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 1.5rem;
}
.hero-badge {
  display: inline-block;
  padding: 0.2rem 0.75rem;
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 0.72rem;
  color: var(--text-dim);
  font-family: var(--font-mono);
  margin-bottom: 0.9rem;
  background: var(--bg-card);
}
.hero-title {
  font-size: clamp(1.6rem, 4vw, 2.2rem);
  font-weight: 800;
  margin: 0 0 0.4rem;
  letter-spacing: -0.02em;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-2) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-sub {
  color: var(--text-dim);
  font-size: 0.9rem;
  margin: 0 0 0.9rem;
}
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  color: var(--text-dim);
  flex-wrap: wrap;
}
.hstat strong { color: var(--text); font-weight: 600; }
.hstat-sep { opacity: 0.4; }

/* ── Filter bar ── */
.filter-wrap {
  margin-bottom: 1.75rem;
  overflow-x: auto;
  scrollbar-width: none;
}
.filter-wrap::-webkit-scrollbar { display: none; }
.filter-bar {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
  min-width: max-content;
}
.fpill {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.3rem 0.7rem;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: transparent;
  color: var(--text-dim);
  font-size: 0.78rem;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.fpill:hover {
  border-color: var(--sc, var(--accent));
  color: var(--sc, var(--accent));
}
.fpill.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
  font-weight: 600;
}
.fpill-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.fpill-favicon {
  border-radius: 2px;
  flex-shrink: 0;
  opacity: 0.85;
}
.fpill-count {
  background: rgba(255,255,255,0.15);
  border-radius: 999px;
  padding: 0 0.35rem;
  font-size: 0.7rem;
  line-height: 1.4;
}
.fpill:not(.active) .fpill-count {
  background: var(--border);
  color: var(--text-dim);
}

/* ── Day group ── */
.day-group { margin-bottom: 2rem; }
.day-label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.6rem;
}
.day-text {
  font-size: 0.78rem;
  font-weight: 700;
  font-family: var(--font-mono);
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.day-count {
  font-size: 0.7rem;
  color: var(--text-dim);
  background: var(--border);
  border-radius: 999px;
  padding: 0.05rem 0.45rem;
}

/* ── Feed list ── */
.feed-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
}

.feed-item {
  border-left: 3px solid var(--ic);
  border-bottom: 1px solid var(--border);
  transition: background 0.12s;
}
.feed-item:last-child { border-bottom: none; }
.feed-item:hover { background: rgba(255,255,255,0.03); }

.feed-link {
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
  padding: 0.9rem 1rem 0.9rem 1rem;
  text-decoration: none;
  color: inherit;
}
.feed-link:hover { text-decoration: none; }

.feed-content { flex: 1; min-width: 0; }

.feed-meta {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  margin-bottom: 0.35rem;
}
.feed-favicon {
  border-radius: 3px;
  opacity: 0.8;
  flex-shrink: 0;
}
.feed-source {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--ic);
}
.feed-sep { font-size: 0.7rem; color: var(--border); }
.feed-time {
  font-size: 0.7rem;
  color: var(--text-dim);
  font-family: var(--font-mono);
}

.feed-title {
  font-size: 0.93rem;
  font-weight: 600;
  line-height: 1.5;
  margin: 0 0 0.3rem;
  color: var(--text);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.feed-item:hover .feed-title { color: var(--accent); }

.feed-summary {
  font-size: 0.78rem;
  color: var(--text-dim);
  line-height: 1.55;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.feed-arrow {
  width: 16px; height: 16px;
  color: var(--border);
  flex-shrink: 0;
  margin-top: 0.15rem;
  transition: color 0.15s, transform 0.15s;
}
.feed-item:hover .feed-arrow {
  color: var(--accent);
  transform: translateX(2px);
}

/* ── Empty ── */
.feed-empty {
  text-align: center;
  padding: 4rem 2rem;
  color: var(--text-dim);
  font-size: 0.9rem;
}
</style>
