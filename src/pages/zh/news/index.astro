---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import newsData from '../../../data/news.json';

const base = import.meta.env.BASE_URL;

const SOURCE_COLORS: Record<string, string> = {
  '量子位':        '#3b82f6',
  '机器之心':      '#8b5cf6',
  '少数派':        '#10b981',
  '36Kr':         '#f59e0b',
  '爱范儿':        '#ef4444',
  '极客公园':      '#06b6d4',
  '新智元':        '#6366f1',
  '虎嗅':         '#f97316',
  '钛媒体':        '#84cc16',
  'IT之家':        '#ec4899',
  'TechCrunch AI': '#7c3aed',
  'The Verge AI':  '#0ea5e9',
  'VentureBeat AI':'#d97706',
  'MIT Tech Review':'#059669',
  'Google AI':     '#4285f4',
  'Hugging Face':  '#ff9d00',
};

const items = newsData.items as {
  title: string; title_zh: string; title_en: string;
  url: string; source: string;
  summary: string; summary_zh: string; summary_en: string;
  date: string;
}[];

// 获取所有来源
const sources = [...new Set(items.map(i => i.source))];
---

<BaseLayout
  title="每日 AI 资讯 · AI 新闻速报"
  description="每日自动抓取量子位、机器之心、少数派等 AI 资讯，掌握最新人工智能动态。"
  lang="zh"
>

  <div class="news-page">
    <!-- 页头 -->
    <div class="news-header">
      <h1 class="news-title">每日 AI 资讯</h1>
      <p class="news-sub">省去刷信息的时间，只看 AI 最重要的事</p>
      <p class="news-updated">更新时间：{newsData.updated}</p>
    </div>

    <!-- 来源筛选 -->
    <div class="filter-bar">
      <button class="filter-btn active" data-source="all">全部 ({items.length})</button>
      {sources.map(src => (
        <button
          class="filter-btn"
          data-source={src}
          style={`--src-color: ${SOURCE_COLORS[src] ?? '#64748b'}`}
        >
          {src} ({items.filter(i => i.source === src).length})
        </button>
      ))}
    </div>

    <!-- 资讯列表 -->
    <ul class="news-list" id="news-list">
      {items.map(item => (
        <li class="news-item" data-source={item.source}>
          <a href={item.url} target="_blank" rel="noopener noreferrer" class="news-link">
            <div class="news-meta">
              <span
                class="news-source"
                style={`background: ${SOURCE_COLORS[item.source] ?? '#64748b'}22; color: ${SOURCE_COLORS[item.source] ?? '#64748b'}`}
              >
                {item.source}
              </span>
              <span class="news-date">{item.date}</span>
            </div>
            <h2 class="news-item-title">{item.title_zh || item.title}</h2>
            {(item.summary_zh || item.summary) && <p class="news-summary">{item.summary_zh || item.summary}</p>}
          </a>
        </li>
      ))}
    </ul>

    {items.length === 0 && (
      <div class="news-empty">暂无资讯，请稍后再来</div>
    )}
  </div>

</BaseLayout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const list = document.getElementById('news-list')!;
  const allItems = Array.from(list.querySelectorAll<HTMLElement>('.news-item'));

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const src = btn.dataset.source ?? 'all';
      allItems.forEach(item => {
        item.style.display = (src === 'all' || item.dataset.source === src) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .news-page { max-width: 760px; margin: 0 auto; padding: 2rem 0 4rem; }

  /* 页头 */
  .news-header {
    text-align: center;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border);
    margin-bottom: 1.5rem;
  }
  .news-title {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    margin: 0 0 0.4rem;
    letter-spacing: -0.02em;
  }
  .news-sub { color: var(--text-dim); font-size: 0.9rem; margin: 0 0 0.3rem; }
  .news-updated { color: var(--text-dim); font-size: 0.75rem; margin: 0; }

  /* 筛选栏 */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }
  .filter-btn {
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: transparent;
    color: var(--text-dim);
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    font-weight: 600;
  }

  /* 资讯列表 */
  .news-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }

  .news-item { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s; }
  .news-item:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }

  .news-link { display: block; padding: 1rem 1.2rem; text-decoration: none; color: inherit; }
  .news-link:hover { text-decoration: none; }

  .news-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.45rem; }
  .news-source {
    font-size: 0.72rem; font-weight: 600;
    padding: 0.1rem 0.5rem; border-radius: 4px;
  }
  .news-date { font-size: 0.72rem; color: var(--text-dim); }

  .news-item-title {
    font-size: 0.95rem; font-weight: 600; margin: 0 0 0.35rem;
    color: var(--text); line-height: 1.5;
  }
  .news-item:hover .news-item-title { color: var(--accent); }

  .news-summary {
    font-size: 0.8rem; color: var(--text-dim); line-height: 1.55; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  .news-empty { text-align: center; padding: 4rem; color: var(--text-dim); }
</style>
