---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { TOOLS } from '../../../data/tools';

const toolEntries = await getCollection('tools-zh');
const detailSlugs = new Set(toolEntries.map(e => e.slug));

const base = import.meta.env.BASE_URL;

const TAG_COLORS: Record<string, string> = {
  '免费': 'tag-free',
  '付费': 'tag-paid',
  '免费/付费': 'tag-freemium',
};

const CATEGORY_COLORS: Record<string, string> = {
  coding:       '#4FACFE',
  models:       '#A855F7',
  writing:      '#10B981',
  image:        '#F59E0B',
  video:        '#EF4444',
  productivity: '#06B6D4',
  audio:        '#EC4899',
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "AI工具导航 2026",
  "description": "2026年最全AI工具导航，收录AI编程、大模型、写作、图像生成、视频生成等各类AI工具，持续更新。",
  "url": Astro.url.href,
};

const CATEGORY_ICONS: Record<string, string> = {
  coding:       `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  models:       `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>`,
  writing:      `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
  image:        `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
  video:        `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
  productivity: `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  audio:        `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
};
---

<BaseLayout title="AI工具导航 2026 · 精选AI工具大全" description="2026年最全AI工具导航，收录AI编程、大模型、写作、图像生成、视频生成等各类AI工具，持续更新。" lang="zh">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="page-header">
    <h1>AI 工具导航 2026</h1>
    <p class="page-desc">精选各类 AI 工具，持续更新 · <a href={`${base}/zh/articles/`}>查看评测文章 →</a></p>
  </div>

  <div class="tools-layout">
    <!-- ── 左侧边栏 ── -->
    <aside class="tools-sidebar">
      <div class="sidebar-search-wrap">
        <svg class="sidebar-search-icon" viewBox="0 0 20 20" fill="none">
          <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.8"/>
          <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        <input
          id="tools-search-input"
          type="text"
          class="sidebar-search-input"
          placeholder="搜索工具..."
          autocomplete="off"
        />
      </div>
      <span id="tools-search-count" class="sidebar-search-count" style="display:none"></span>
      <nav class="sidebar-nav" id="tools-cat-nav">
        {TOOLS.map(cat => (
          <a
            href={`#${cat.slug}`}
            class="sidebar-nav-item"
            data-cat={cat.slug}
            style={`--cat-color: ${CATEGORY_COLORS[cat.slug] ?? '#4FACFE'}`}
          >
            <span class="sidebar-nav-icon"><Fragment set:html={CATEGORY_ICONS[cat.slug] || ''} /></span>
            {cat.category}
          </a>
        ))}
      </nav>
    </aside>

    <!-- ── 主内容区 ── -->
    <div class="tools-main">
      {TOOLS.map(cat => {
        const catColor = CATEGORY_COLORS[cat.slug] ?? '#4FACFE';
        // 将 hex 转为 rgb 分量，用于半透明背景
        const r = parseInt(catColor.slice(1,3), 16);
        const g = parseInt(catColor.slice(3,5), 16);
        const b = parseInt(catColor.slice(5,7), 16);
        return (
          <section
            class="tool-section"
            id={cat.slug}
            style={`--section-color: ${catColor}; --section-color-rgb: ${r},${g},${b};`}
          >
            <h2 class="section-title">
              <span class="section-title-bar"></span>
              {cat.category}
            </h2>
            <ul class="tool-grid">
              {cat.items.map(tool => {
                const hasDetail = detailSlugs.has(tool.slug);
                const href = hasDetail ? `${base}/zh/tools/${tool.slug}/` : tool.url;
                const isExternal = !hasDetail;
                return (
                  <li class="tool-card">
                    <a
                      href={href}
                      target={isExternal ? '_blank' : undefined}
                      rel={isExternal ? 'noopener noreferrer' : undefined}
                      class="tool-card-link"
                    >
                      <div class="tool-card-top">
                        <span class="tool-name-wrap">
                          <img
                            src={`https://www.google.com/s2/favicons?domain=${new URL(tool.url).hostname}&sz=32`}
                            alt={tool.name}
                            width="24" height="24"
                            class="tool-favicon"
                            loading="lazy"
                          />
                          <span class="tool-name">{tool.name}</span>
                        </span>
                        <span class={`tool-tag ${TAG_COLORS[tool.tag] || 'tag-freemium'}`}>{tool.tag}</span>
                      </div>
                      <p class="tool-desc">{tool.desc}</p>
                      <span class="tool-visit">{hasDetail ? '查看详情 →' : '访问 →'}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </section>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .page-desc {
    color: var(--text-dim);
    margin-top: 0.25rem;
    font-size: 0.95rem;
  }
  .page-desc a { color: var(--accent); font-size: 0.875rem; }

  /* ── 双栏布局 ── */
  .tools-layout {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  /* ── 左侧边栏 ── */
  .tools-sidebar {
    width: 228px;
    flex-shrink: 0;
    position: sticky;
    top: 68px;
    max-height: calc(100vh - 84px);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .tools-sidebar::-webkit-scrollbar { display: none; }

  .sidebar-search-wrap {
    position: relative;
    margin-bottom: 14px;
  }
  .sidebar-search-icon {
    position: absolute;
    left: 0.7rem;
    top: 50%;
    transform: translateY(-50%);
    width: 15px; height: 15px;
    color: var(--text-dim);
    pointer-events: none;
  }
  .sidebar-search-input {
    width: 100%;
    padding: 0.55rem 0.8rem 0.55rem 2.2rem;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    background: var(--bg-card);
    color: var(--text);
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .sidebar-search-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(79,172,254,0.12);
  }
  .sidebar-search-input::placeholder { color: var(--text-dim); }

  .sidebar-search-count {
    display: block;
    font-size: 0.72rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
    margin-bottom: 10px;
    padding-left: 4px;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  /* 侧边栏导航项：默认态 */
  .sidebar-nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 7px;
    font-size: 0.9rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: background 0.15s, color 0.15s, border-left-color 0.15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    border-left: 2px solid transparent;
  }
  .sidebar-nav-icon {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    opacity: 0.55;
    transition: opacity 0.15s, color 0.15s;
  }

  /* 悬停：使用分类颜色 */
  .sidebar-nav-item:hover {
    background: rgba(var(--cat-color-rgb, 79,172,254), 0.07);
    color: var(--cat-color, var(--accent));
    text-decoration: none;
  }
  .sidebar-nav-item:hover .sidebar-nav-icon {
    opacity: 1;
    color: var(--cat-color, var(--accent));
  }

  /* 激活态：使用分类颜色 */
  .sidebar-nav-item.active {
    background: rgba(var(--cat-color-rgb, 79,172,254), 0.1);
    color: var(--cat-color, var(--accent));
    font-weight: 500;
    border-left-color: var(--cat-color, var(--accent));
  }
  .sidebar-nav-item.active .sidebar-nav-icon {
    opacity: 1;
    color: var(--cat-color, var(--accent));
  }

  /* ── 主内容区 ── */
  .tools-main { flex: 1; min-width: 0; }

  /* section 区块：带分类底色 */
  .tool-section {
    margin-bottom: 2rem;
    background: rgba(var(--section-color-rgb, 79,172,254), 0.02);
    border: 1px solid rgba(var(--section-color-rgb, 79,172,254), 0.07);
    border-radius: 14px;
    padding: 18px 20px;
  }

  /* section 标题：左侧彩色竖线 + 底部彩色分割线 */
  .section-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.875rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid rgba(var(--section-color-rgb, 79,172,254), 0.2);
    color: var(--text);
  }
  .section-title-bar {
    display: inline-block;
    width: 4px;
    height: 1.1em;
    border-radius: 2px;
    background: var(--section-color, var(--accent));
    flex-shrink: 0;
  }

  .tool-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 1100px) { .tool-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .tool-grid { grid-template-columns: 1fr; } }

  /* 工具卡片：彩色顶边框 + 分类色背景渐变 */
  .tool-card {
    background: linear-gradient(
      160deg,
      rgba(var(--section-color-rgb, 79,172,254), 0.05) 0%,
      var(--bg-card) 55%
    );
    border: 1px solid rgba(var(--section-color-rgb, 79,172,254), 0.13);
    border-top: 3px solid var(--section-color, var(--accent));
    border-radius: 10px;
    transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s, background 0.2s;
  }
  .tool-card:hover {
    background: linear-gradient(
      160deg,
      rgba(var(--section-color-rgb, 79,172,254), 0.1) 0%,
      var(--bg-card) 60%
    );
    border-color: var(--section-color, var(--accent));
    transform: translateY(-3px);
    box-shadow: 0 10px 40px rgba(var(--section-color-rgb, 79,172,254), 0.14);
  }
  .tool-card-link {
    display: flex;
    flex-direction: column;
    padding: 14px 16px;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }
  .tool-card-link:hover { text-decoration: none; }
  .tool-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .tool-name-wrap { display: flex; align-items: center; gap: 8px; }
  .tool-favicon { border-radius: 6px; flex-shrink: 0; }
  .tool-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    transition: color 0.15s;
  }
  .tool-card:hover .tool-name { color: var(--section-color, var(--accent)); }
  .tool-tag {
    font-size: 11px;
    font-family: var(--font-mono);
    padding: 2px 7px;
    border-radius: 4px;
    border: 1px solid;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .tag-free     { color: var(--green);    border-color: rgba(63,185,80,0.3);   background: rgba(63,185,80,0.07); }
  .tag-paid     { color: var(--accent-2); border-color: rgba(188,140,255,0.3); background: rgba(188,140,255,0.07); }
  .tag-freemium { color: var(--accent);   border-color: rgba(88,166,255,0.3);  background: rgba(88,166,255,0.07); }

  .tool-desc {
    font-size: 12.5px;
    color: var(--text-dim);
    line-height: 1.5;
    flex: 1;
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* visit 链接颜色跟随分类色 */
  .tool-visit {
    font-size: 12px;
    color: var(--section-color, var(--accent));
    font-family: var(--font-mono);
  }

  .tool-card.hidden { display: none; }
  .tool-section.section-hidden { display: none; }

  /* ── 移动端：侧边栏转为顶部横排 ── */
  @media (max-width: 768px) {
    .tools-layout { flex-direction: column; gap: 12px; }
    .tools-sidebar {
      width: 100%;
      position: static;
      max-height: none;
    }
    .sidebar-search-wrap { max-width: 100%; }
    .sidebar-nav {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 6px;
    }
    .sidebar-nav-item {
      border: 1px solid var(--border);
      border-left: 1px solid var(--border);
      border-radius: 999px;
      font-size: 0.8rem;
      padding: 4px 12px;
    }
    .sidebar-nav-item:hover,
    .sidebar-nav-item.active {
      border-color: var(--cat-color, var(--accent));
      background: rgba(var(--cat-color-rgb, 79,172,254), 0.1);
    }
  }
</style>

<script>
  // ── 将 hex 颜色转为 rgb 分量字符串，供 rgba() 使用 ──
  function hexToRgb(hex: string): string {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `${r},${g},${b}`;
  }

  // ── 给侧边栏 nav item 注入 --cat-color-rgb，供 rgba() 半透明背景使用 ──
  const navItems = Array.from(document.querySelectorAll<HTMLElement>('.sidebar-nav-item'));
  navItems.forEach(item => {
    const color = item.style.getPropertyValue('--cat-color').trim();
    if (color) {
      item.style.setProperty('--cat-color-rgb', hexToRgb(color));
    }
  });

  // ── 搜索逻辑 ──
  const input = document.getElementById('tools-search-input') as HTMLInputElement;
  const countEl = document.getElementById('tools-search-count')!;
  const sections = Array.from(document.querySelectorAll<HTMLElement>('.tool-section'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.tool-card'));

  const cardTexts = cards.map(card => {
    const name = card.querySelector('.tool-name')?.textContent ?? '';
    const desc = card.querySelector('.tool-desc')?.textContent ?? '';
    return (name + ' ' + desc).toLowerCase();
  });

  input.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();

    if (!q) {
      cards.forEach(c => c.classList.remove('hidden'));
      sections.forEach(s => s.classList.remove('section-hidden'));
      countEl.style.display = 'none';
      return;
    }

    let matched = 0;
    cards.forEach((card, i) => {
      if (cardTexts[i].includes(q)) {
        card.classList.remove('hidden');
        matched++;
      } else {
        card.classList.add('hidden');
      }
    });

    sections.forEach(sec => {
      const visible = sec.querySelectorAll('.tool-card:not(.hidden)').length > 0;
      sec.classList.toggle('section-hidden', !visible);
    });

    countEl.textContent = `找到 ${matched} 个工具`;
    countEl.style.display = '';
  });

  input.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') {
      input.value = '';
      input.dispatchEvent(new Event('input'));
    }
  });

  // ── 滚动时高亮侧边栏对应分类（active 态颜色由 CSS var 自动处理）──
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navItems.forEach(item => {
          item.classList.toggle('active', item.getAttribute('data-cat') === id);
        });
      }
    });
  }, { rootMargin: '-15% 0px -70% 0px', threshold: 0 });

  sections.forEach(s => observer.observe(s));
</script>
