---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<BaseLayout title="AI 博客 · 首页">
  <div class="page-header">
    <h1>AI 技术教程</h1>
    <p>由 Claude Opus 4.6 自动生成，聚焦 AI Agent、大模型应用开发</p>
  </div>

  {posts.length === 0 ? (
    <div class="empty">
      <p>暂无文章。运行 <code>python main.py</code> 生成第一篇。</p>
    </div>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`${import.meta.env.BASE_URL}/posts/${post.slug}`} class="post-card">
            <div class="post-card-meta">
              <span class="post-date">{formatDate(post.data.date)}</span>
              <span class="badge badge-difficulty">{post.data.difficulty}</span>
            </div>
            <h2>{post.data.title}</h2>
            {post.data.summary && (
              <p class="post-summary">{post.data.summary}</p>
            )}
            <div class="tag-list">
              {post.data.tags.map((tag) => (
                <span class="tag">#{tag}</span>
              ))}
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
