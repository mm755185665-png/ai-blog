---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('tools-en');
  return entries.map(entry => ({ params: { slug: entry.slug } }));
}

const { slug } = Astro.params;
const entries = await getCollection('tools-en');
const entry = entries.find(e => e.slug === slug);
if (!entry) return Astro.redirect('/en/tools/');

const { Content } = await entry.render();
const data = entry.data;
const base = import.meta.env.BASE_URL;

const domain = new URL(data.url).hostname;
const faviconUrl = `https://www.google.com/s2/favicons?domain=${domain}&sz=64`;

// Similar tools: same category, different slug
const allEntries = await getCollection('tools-en');
const similarTools = allEntries
  .filter(e => e.data.category === data.category && e.slug !== slug)
  .slice(0, 3);

const TAG_COLORS: Record<string, string> = {
  'Free':      'tag-free',
  'Paid':      'tag-paid',
  'Free/Paid': 'tag-freemium',
};
---

<BaseLayout title={`${data.name} - AI Tool Review`} description={data.longDesc} lang="en">
  <div class="tool-detail">

    <div class="tool-hero">
      <div class="tool-hero-left">
        <img src={faviconUrl} alt={data.name} class="tool-favicon" width="48" height="48" />
        <div>
          <h1 class="tool-title">{data.name}</h1>
          <div class="tool-meta">
            <span class="tool-category">{data.category}</span>
            <span class={`tool-tag ${TAG_COLORS[data.tag] || 'tag-freemium'}`}>{data.tag}</span>
          </div>
        </div>
      </div>
      <a href={data.url} target="_blank" rel="noopener noreferrer" class="btn-visit">
        Visit Site →
      </a>
    </div>

    <p class="tool-longdesc">{data.longDesc}</p>

    {data.features.length > 0 && (
      <section class="tool-section">
        <h2>Key Features</h2>
        <ul class="feature-list">
          {data.features.map(f => <li>{f}</li>)}
        </ul>
      </section>
    )}

    {data.pricing && (
      <section class="tool-section">
        <h2>Pricing</h2>
        <p class="pricing-text">{data.pricing}</p>
      </section>
    )}

    {(data.pros.length > 0 || data.cons.length > 0) && (
      <section class="tool-section proscons">
        <div class="pros">
          <h2>✓ Pros</h2>
          <ul>{data.pros.map(p => <li>{p}</li>)}</ul>
        </div>
        <div class="cons">
          <h2>✗ Cons</h2>
          <ul>{data.cons.map(c => <li>{c}</li>)}</ul>
        </div>
      </section>
    )}

    <section class="tool-section prose">
      <Content />
    </section>

    {similarTools.length > 0 && (
      <section class="tool-section">
        <h2>Similar Tools</h2>
        <div class="similar-tools">
          {similarTools.map(t => (
            <a href={`${base}/en/tools/${t.slug}/`} class="similar-tool-card">
              <img
                src={`https://www.google.com/s2/favicons?domain=${new URL(t.data.url).hostname}&sz=32`}
                alt={t.data.name} width="20" height="20"
              />
              <span>{t.data.name}</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .tool-detail { max-width: 760px; }
  .tool-hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem 0 1rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }
  .tool-hero-left { display: flex; align-items: center; gap: 1rem; }
  .tool-favicon { border-radius: 10px; border: 1px solid var(--border); }
  .tool-title { font-size: 1.6rem; font-weight: 700; margin: 0 0 0.3rem; color: var(--text); }
  .tool-meta { display: flex; align-items: center; gap: 0.5rem; }
  .tool-category { font-size: 0.8rem; color: var(--text-dim); }
  .tool-tag {
    font-size: 11px;
    font-family: var(--font-mono);
    padding: 2px 7px;
    border-radius: 4px;
    border: 1px solid;
  }
  .tag-free     { color: var(--green);    border-color: rgba(63,185,80,0.3);   background: rgba(63,185,80,0.07); }
  .tag-paid     { color: var(--accent-2); border-color: rgba(188,140,255,0.3); background: rgba(188,140,255,0.07); }
  .tag-freemium { color: var(--accent);   border-color: rgba(88,166,255,0.3);  background: rgba(88,166,255,0.07); }
  .btn-visit {
    display: inline-block;
    padding: 0.5rem 1.2rem;
    background: var(--accent);
    color: #fff;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .btn-visit:hover { opacity: 0.85; text-decoration: none; }
  .tool-longdesc { font-size: 1rem; color: var(--text-dim); line-height: 1.7; margin-bottom: 2rem; }
  .tool-section { margin-bottom: 2rem; }
  .tool-section h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .feature-list { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .feature-list li::before { content: '·  '; color: var(--accent); }
  .feature-list li { font-size: 0.95rem; color: var(--text-dim); }
  .pricing-text { font-size: 0.95rem; color: var(--text-dim); line-height: 1.6; }
  .proscons { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  @media (max-width: 560px) { .proscons { grid-template-columns: 1fr; } }
  .pros h2 { color: var(--green); border-color: rgba(63,185,80,0.2); }
  .cons h2 { color: var(--accent-2); border-color: rgba(188,140,255,0.2); }
  .pros ul, .cons ul { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .pros li, .cons li { font-size: 0.9rem; color: var(--text-dim); }
  .prose { font-size: 0.95rem; line-height: 1.7; color: var(--text-dim); }
  .prose :global(h2) { font-size: 1.1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: var(--text); }
  .prose :global(p) { margin-bottom: 0.75rem; }
  .similar-tools { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .similar-tool-card {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.875rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .similar-tool-card:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }
</style>
