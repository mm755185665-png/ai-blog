---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts-en');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout title="AI Tools Reviews & Tutorials 2026" description="The most comprehensive AI tools reviews and tutorials in 2026, covering free AI tools, AI coding assistants, AI image generators." lang="en">
  <div class="page-header">
    <h1>AI Tools & Tutorials</h1>
  </div>

  {posts.length === 0 ? (
    <div class="empty"><p>No articles yet. Check back soon.</p></div>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-card">
          {post.data.cover && (
            <a href={`${import.meta.env.BASE_URL}/en/posts/${post.slug}/`}>
              <img src={post.data.cover} alt={post.data.title} class="post-card-cover" />
            </a>
          )}
          <div class="post-card-meta">
            <span class="post-date">{formatDate(post.data.date)}</span>
            <span class="badge badge-difficulty">{post.data.difficulty}</span>
          </div>
          <h2><a href={`${import.meta.env.BASE_URL}/en/posts/${post.slug}/`}>{post.data.title}</a></h2>
          {post.data.summary && <p class="post-summary">{post.data.summary}</p>}
          <div class="tag-list">
            {post.data.tags.map((tag) => (
              <a href={`${import.meta.env.BASE_URL}/en/tags/${tag}/`} class="tag">#{tag}</a>
            ))}
          </div>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
