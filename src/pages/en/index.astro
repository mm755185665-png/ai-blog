---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts-en');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout title="AI Tools Reviews & Tutorials 2026" description="The most comprehensive AI tools reviews and tutorials in 2026, covering free AI tools, AI coding assistants, AI image generators." lang="en">
  <div class="page-header">
    <h1>AI Tools & Tutorials</h1>
  </div>

  {posts.length === 0 ? (
    <div class="empty"><p>No articles yet. Check back soon.</p></div>
  ) : (
    <ul class="post-grid">
      {posts.map((post) => (
        <li class="post-card">
          <a href={`${import.meta.env.BASE_URL}/en/posts/${post.slug}/`} class="post-card-link">
            {post.data.cover
              ? <img src={post.data.cover} alt={post.data.title} class="post-card-cover" />
              : <div class="post-card-cover post-card-cover--placeholder" />
            }
            <div class="post-card-body">
              <div class="post-card-meta">
                <span class="tag">{post.data.tags[0] ? `#${post.data.tags[0]}` : ''}</span>
                <span class="post-date">{formatDate(post.data.date)}</span>
              </div>
              <h2>{post.data.title}</h2>
              {post.data.summary && <p class="post-summary">{post.data.summary}</p>}
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
