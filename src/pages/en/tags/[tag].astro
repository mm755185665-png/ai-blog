---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts-en');
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: { tag, posts: posts.filter((p) => p.data.tags.includes(tag)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()) },
  }));
}

const { tag, posts } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout title={`#${tag} · AI Blog`} description={`All articles about ${tag}`} lang="en">
  <div class="page-header">
    <h1>#{tag}</h1>
    <p>{posts.length} articles</p>
  </div>

  <ul class="post-list">
    {posts.map((post) => (
      <li class="post-card">
        <div class="post-card-meta">
          <span class="post-date">{formatDate(post.data.date)}</span>
          <span class="badge badge-difficulty">{post.data.difficulty}</span>
        </div>
        <h2><a href={`${import.meta.env.BASE_URL}/en/posts/${post.slug}/`}>{post.data.title}</a></h2>
        {post.data.summary && <p class="post-summary">{post.data.summary}</p>}
      </li>
    ))}
  </ul>
</BaseLayout>
